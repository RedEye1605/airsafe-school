# =============================================================================
# AirSafe School — Python .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Data files (large, downloaded/generated)
*.csv
*.zip
*.gz
*.tar
*.tar.gz
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz
data/raw/
data/processed/

# Keep directory structure with .gitkeep
!**/.gitkeep

# Large media
*.mp4
*.avi
*.mov
*.mkv
*.wav
*.mp3

# Generated HTML reports
data/*.html

# Models (large binary)
*.pt
*.pth
*.onnx
*.bin
*.safetensors
*.ckpt
# Allow specific model files needed for prediction
!models/final_lgbm_h6.pkl
!models/final_lgbm_h12.pkl
!models/final_lgbm_h24.pkl
!models/hourly_residual_corrector.pkl
!models/station_stats_lookup.json

# Jupyter
.ipynb_checkpoints/
notebooks/

# Test/cache
cache/
.pytest_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.local
.env.production

# Logs
*.log
logs/

# Azure Functions local settings (may contain secrets)
azure-functions/local.settings.json

# Output (keep .gitkeep)
output/**
!output/.gitkeep

# Tracker files (temp)
TRACKER_UPDATE_SUMMARY.txt
