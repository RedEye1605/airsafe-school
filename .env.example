# AirSafe School — Environment Variables
# Copy this file to .env and fill in values.

# ── Paths ────────────────────────────────────────────────────────────────
# AIRSAFE_ROOT=/path/to/airsafe-school
# DATA_DIR=/path/to/airsafe-school/data
# OUTPUT_DIR=/path/to/airsafe-school/output

# ── SPKU API ─────────────────────────────────────────────────────────────
# SPKU_API_URL=https://udara.jakarta.go.id/api/lokasi_stasiun_udara
# SPKU_STALE_DAYS=7
# SPKU_REQUEST_TIMEOUT=30
# SPKU_MAX_STATIONS=500

# ── Open-Meteo Weather ───────────────────────────────────────────────────
# OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
# OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
# JAKARTA_LAT=-6.2
# JAKARTA_LON=106.85
# WEATHER_REQUEST_TIMEOUT=60

# ── BMKG Weather API ────────────────────────────────────────────────────
# BMKG_BASE_URL=https://api.bmkg.go.id/publik/prakiraan-cuaca
# BMKG_ADM4_CODES=31.71.03.1001
# BMKG_REQUEST_TIMEOUT=60

# ── Nominatim Geocoding ──────────────────────────────────────────────────
# NOMINATIM_URL=https://nominatim.openstreetmap.org/search
# NOMINATIM_USER_AGENT=AirSafeSchool/1.0 (your@email.com)
# NOMINATIM_RATE_LIMIT=1.1

# ── School Data ──────────────────────────────────────────────────────────
# SCHOOL_REGISTRY_BASE_URL=https://referensi.data.kemendikdasmen.go.id

# ── Azure Blob Storage ──────────────────────────────────────────────────
# AIRSAFE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AIRSAFE_RAW_CONTAINER=raw
# AIRSAFE_PROCESSED_CONTAINER=processed
# AIRSAFE_LOG_CONTAINER=logs

# ── ETL Schedule (NCRONTAB, UTC) ────────────────────────────────────────
# ETL_SCHEDULE=0 5 * * * *

# ── Azure Functions Local Mode ───────────────────────────────────────────
# AIRSAFE_LOCAL_MODE=1
